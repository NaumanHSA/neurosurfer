# ── LLM provider ────────────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic          # "anthropic" | "openai"
# MODEL=claude-opus-4-8
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=not-needed
# CONTEXT_WINDOW=200000

# ── Observability / tracing (pip install "neurosurfer[observability]") ───────
# Set a backend's connection vars and tracing auto-activates on the next run.
#
# Langfuse (traces, token cost, sessions):
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com     # or your self-hosted URL
#
# OpenTelemetry (any OTLP backend: Phoenix, Grafana, Datadog, …):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
#
# Override auto-detection: force off with "none", or pin an explicit set.
# NEUROSURFER_EXPORTERS=none
# NEUROSURFER_EXPORTERS=langfuse,otel
# NEUROSURFER_SERVICE_NAME=neurosurfer

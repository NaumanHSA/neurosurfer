# The neurosurfer gateway the studio talks to. In `npm run dev` Vite proxies
# /v1/* to this host (see vite.config.ts). Override at build time for deploys.
NEUROSURFER_GATEWAY=http://localhost:8000

# Bearer token for the gateway, if its auth middleware is enabled.
# Left blank for an open local gateway (the M0 default).
VITE_NEUROSURFER_TOKEN=
